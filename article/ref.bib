@article{perarnau_lonely_2025,
    title = {The {Lonely} {Runner} {Conjecture} turns 60},
    volume = {58},
    issn = {15740137},
    url = {https://linkinghub.elsevier.com/retrieve/pii/S1574013725000747},
    doi = {10.1016/j.cosrev.2025.100798},
    abstract = {The Lonely Runner Conjecture originated in Diophantine approximation is turning 60. Even if the conjecture is still widely open, the flow of partial results, innovative tools and connections to different problems and applications has been steady on its long life. This survey attempts to give a panoramic view of the status of the problem, trying to highlight the contributions of the many papers that it has originated.},
    urldate = {2026-03-18},
    journal = {Computer Science Review},
    author = {Perarnau, Guillem and Serra, Oriol},
    month = nov,
    year = {2025},
    pages = {100798},
}
@article{perarnau_correlation_2016,
    title = {Correlation {Among} {Runners} and {Some} {Results} on the {Lonely} {Runner} {Conjecture}},
    volume = {23},
    issn = {1077-8926},
    url = {https://www.combinatorics.org/ojs/index.php/eljc/article/view/v23i1p50},
    doi = {10.37236/5123},
    abstract = {The Lonely Runner Conjecture, posed independently by Wills and by Cusick, states that for any set of runners running along the unit circle with constant diﬀerent speeds and starting at the same point, there is a time where all of them are far enough from the origin. We study the correlation among the time that runners spend close to the origin. By means of these correlations, we improve a result of Chen on the gap of loneliness. In the last part, we introduce dynamic interval graphs to deal with a weak version of the conjecture thus providing a new result related to the invisible runner theorem of Czerwi´nski and Grytczuk.},
    number = {1},
    urldate = {2026-03-18},
    journal = {Electronic Journal of Combinatorics},
    author = {Perarnau, Guillem and Serra, Oriol},
    month = mar,
    year = {2016},
    pages = {P1.50},
}
